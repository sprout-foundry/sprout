{
  "auth": {
    "env_var": "DEEPSEEK_API_KEY",
    "type": "bearer"
  },
  "cost": {
    "currency": "USD",
    "input_token_cost": 0.14,
    "output_token_cost": 0.28
  },
  "defaults": {
    "max_tokens": 32768,
    "model": "deepseek-v4-flash",
    "temperature": 0.7,
    "top_p": 1
  },
  "endpoint": "https://api.deepseek.com/v1/chat/completions",
  "headers": {},
  "message_conversion": {
    "convert_tool_role_to_user": false,
    "include_tool_call_id": true,
    "reasoning_content_field": "reasoning_content"
  },
  "models": {
    "available_models": [],
    "default_context_limit": 1000000,
    "default_model": "deepseek-v4-flash",
    "model_overrides": {
      "deepseek-chat": 1000000,
      "deepseek-coder": 128000,
      "deepseek-reasoner": 1000000,
      "deepseek-v3": 128000,
      "deepseek-v4-flash": 1000000,
      "deepseek-v4-pro": 1000000
    },
    "pattern_overrides": [
      {
        "context_limit": 1000000,
        "pattern": "deepseek-v4-.*"
      },
      {
        "context_limit": 128000,
        "pattern": "deepseek-v3.*"
      },
      {
        "context_limit": 128000,
        "pattern": "deepseek-coder.*"
      }
    ],
    "supports_vision": false,
    "vision_model": ""
  },
  "name": "deepseek",
  "retry": {
    "backoff_multiplier": 2,
    "base_delay_ms": 1000,
    "max_attempts": 3,
    "max_delay_ms": 30000,
    "retryable_errors": [
      "rate_limit_exceeded",
      "temporary_error",
      "timeout"
    ]
  },
  "streaming": {
    "chunk_timeout_ms": 320000,
    "done_marker": "[DONE]",
    "format": "sse"
  }
}