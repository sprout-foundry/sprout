{
  "__comment": "Full Autonomous TODO Processor — customize provider/model/subagent_overrides before running.",
  "__runCommand": "sprout agent --workflow-config automate/workflow.json",
  "continue_on_error": true,
  "description": "Processes TODO.md items one at a time with full build/test/review cycle, then commits each.",
  "initial": {
    "max_iterations": 500,
    "model": "REPLACE_WITH_PRIMARY_MODEL",
    "persona": "coordinator",
    "prompt_file": "automate/workflow_prompt.md",
    "provider": "REPLACE_WITH_PRIMARY_PROVIDER",
    "risk_profile": "permissive",
    "skip_prompt": true,
    "subagent_overrides": {
      "reviewer": {
        "model": "REPLACE_WITH_SUBAGENT_MODEL",
        "provider": "REPLACE_WITH_SUBAGENT_PROVIDER"
      },
      "coder": {
        "model": "REPLACE_WITH_SUBAGENT_MODEL",
        "provider": "REPLACE_WITH_SUBAGENT_PROVIDER"
      },
      "debugger": {
        "model": "REPLACE_WITH_SUBAGENT_MODEL",
        "provider": "REPLACE_WITH_SUBAGENT_PROVIDER"
      },
      "repo_orchestrator": {
        "model": "REPLACE_WITH_SUBAGENT_MODEL",
        "provider": "REPLACE_WITH_SUBAGENT_PROVIDER"
      },
      "tester": {
        "model": "REPLACE_WITH_SUBAGENT_MODEL",
        "provider": "REPLACE_WITH_SUBAGENT_PROVIDER"
      }
    }
  },
  "no_web_ui": true,
  "persist_runtime_overrides": false,
  "budget": {
    "usd": 10.00,
    "warn_at": [0.5, 0.8],
    "on_exceed": "truncate"
  },
  "progress": {
    "heartbeat_seconds": 600
  }
}