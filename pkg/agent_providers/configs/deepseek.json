        "name": "DeepSeek V4 Flash Max",
        "tags": [
          "coding",
          "tools",
          "reasoning"
        ]
      },
      {
        "context_length": 128000,
        "description": "DeepSeek-V3 - Previous generation model",
        "id": "deepseek-v3",
