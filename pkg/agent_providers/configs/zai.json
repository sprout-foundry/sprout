      "glm-5v-turbo": 200000,
      "glm-5.1": 200000,
      "glm-5.2": 1048576
    },
    "pattern_overrides": [
      {
        "context_limit": 200000,
        "pattern": "glm-5.*"
      },
      {
        "context_limit": 200000,
        "pattern": "glm-4\\.6.*"
      },
      {
        "context_limit": 200000,
        "pattern": "glm-4\\.[7-9].*"
      },
      {
        "context_limit": 128000,
        "pattern": "glm-4.*"
      },
      {
        "context_limit": 128000,
        "pattern": "glm-3.*"
      }
    ],
    "supports_vision": true,
    "vision_model": "glm-5v-turbo"
  },
  "name": "zai",
  "retry": {
    "backoff_multiplier": 2,
    "base_delay_ms": 1000,
    "max_attempts": 3,
    "max_delay_ms": 30000,
    "retryable_errors": [
      "rate_limit_exceeded",
      "temporary_error",
      "timeout"
    ]
  },
  "streaming": {
    "chunk_timeout_ms": 320000,
    "done_marker": "[DONE]",
    "format": "sse"
  },
  "display_name": "Z.AI"
}