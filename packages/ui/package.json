{
  "dependencies": {},
  "description": "Sprout UI component library — reusable React components extracted from the Sprout IDE",
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "lucide-react": "^1.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^4.9.0"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@sprout/ui",
  "peerDependencies": {
    "lucide-react": ">=0.300.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "scripts": {
    "build": "tsc && cp src/components/*.css dist/components/",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "dist/index.d.ts",
  "version": "0.1.0"
}