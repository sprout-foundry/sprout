{
  "auth": {
  "env_var": "OPENROUTER_API_KEY",
  "type": "bearer"
},
  "cost": {
  "currency": "USD",
  "input_token_cost": 0,
  "output_token_cost": 0
},
  "defaults": {
  "max_tokens": -1,
  "model": "openai/gpt-5",
  "temperature": 0.7,
  "top_p": 1
},
  "endpoint": "https://openrouter.ai/api/v1/chat/completions",
  "headers": {
  "HTTP-Referer": "https://github.com/sprout-foundry/sprout",
  "X-Title": "Sprout"
},
  "message_conversion": {
  "cache_control": true,
  "convert_tool_role_to_user": false,
  "include_tool_call_id": true,
  "reasoning_content_field": "reasoning_content"
},
  "models": {
  "available_models": [],
  "completion_pattern_overrides": [
  {
  "context_limit": 128000,
  "pattern": "openai/gpt-5.*"
}
],
  "default_context_limit": 128000,
  "default_max_completion_tokens": 128000,
  "default_model": "openai/gpt-5",
  "max_completion_overrides": {
  "openai/gpt-5": 128000,
  "openai/gpt-5-turbo": 128000
},
  "model_overrides": {
  "anthropic/claude-3-5-haiku": 200000,
  "anthropic/claude-3-5-sonnet": 200000,
  "anthropic/claude-3-haiku": 200000,
  "anthropic/claude-3-opus": 200000,
  "anthropic/claude-3-sonnet": 200000,
  "google/gemini-1.5-flash": 1048576,
  "google/gemini-1.5-pro": 2097152,
  "google/gemini-2.0-flash-exp": 1048576,
  "meta-llama/llama-3-70b": 8192,
  "meta-llama/llama-3.1-405b": 131072,
  "meta-llama/llama-3.1-70b": 131072,
  "meta-llama/llama-3.1-8b": 131072,
  "microsoft/wizardlm-2-8x22b": 65536,
  "mistralai/mistral-large": 32768,
  "openai/gpt-5": 272000,
  "openai/gpt-5-turbo": 272000,
  "qwen/qwen-2.5-72b": 32768
},
  "pattern_overrides": [
  {
  "context_limit": 128000,
  "pattern": "gpt-4.*"
},
  {
  "context_limit": 16385,
  "pattern": "gpt-3\\.5.*"
},
  {
  "context_limit": 200000,
  "pattern": "claude-.*"
},
  {
  "context_limit": 131072,
  "pattern": "llama-3.*"
},
  {
  "context_limit": 1048576,
  "pattern": "gemini-.*"
}
],
  "supports_vision": true,
  "vision_model": "google/gemma-3-27b-it",
  "default_model_patterns": [
  ":free"
]
},
  "name": "openrouter",
  "retry": {
  "backoff_multiplier": 2,
  "base_delay_ms": 1000,
  "max_attempts": 3,
  "max_delay_ms": 30000,
  "retryable_errors": [
  "rate_limit_exceeded",
  "temporary_error",
  "timeout"
]
},
  "streaming": {
  "chunk_timeout_ms": 300000,
  "done_marker": "[DONE]",
  "format": "sse"
},
  "display_name": "OpenRouter (Recommended)"
}