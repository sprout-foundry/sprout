{
  "auth": {
    "env_var": "DEEPSEEK_API_KEY",
    "type": "bearer"
  },
  "cost": {
    "currency": "USD",
    "input_token_cost": 0.3,
    "output_token_cost": 0.5
  },
  "defaults": {
    "max_tokens": 32768,
    "model": "deepseek-v4-flash",
    "temperature": 0.7,
    "top_p": 1
  },
  "endpoint": "https://api.deepseek.com/v1/chat/completions",
  "headers": {},
  "message_conversion": {
    "convert_tool_role_to_user": false,
    "include_tool_call_id": true,
    "reasoning_content_field": "reasoning_content"
  },
  "models": {
    "available_models": [
      "deepseek-v4-flash",
      "deepseek-v4-pro",
      "deepseek-v4-flash-max",
      "deepseek-v3",
      "deepseek-chat",
      "deepseek-reasoner",
      "deepseek-coder"
    ],
    "default_context_limit": 1000000,
    "default_model": "deepseek-v4-flash",
    "model_info": [
      {
