{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "prettier"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": [
    "@typescript-eslint",
    "import"
  ],
  "root": true,
  "rules": {
    "import/no-restricted-paths": [
      "error",
      {
        " basePath": ".",
        "zones": [
          {
            "from": "webui/**",
            "message": "packages/ui must never import from webui. This violates the one-way import direction: webui → @sprout/ui",
            "target": "src/**"
          }
        ]
      }
    ]
  }
}