{
  "__runCommand": "sprout agent --workflow-config automate/workflow.json",
  "budget": {
    "on_exceed": "truncate",
    "usd": 10,
    "warn_at": [
      0.5,
      0.8
    ]
  },
  "continue_on_error": true,
  "description": "Processes TODO.md items one at a time with full build/test/review cycle, then commits each. All roles use DeepSeek v4 Flash.",
  "initial": {
    "max_iterations": 0,
    "model": "deepseek-v4-flash",
    "persona": "coordinator",
    "prompt_file": "automate/workflow_prompt.md",
    "provider": "deepseek",
    "risk_profile": "permissive",
    "skip_prompt": true
  },
  "no_web_ui": true,
  "persist_runtime_overrides": false,
  "progress": {
    "heartbeat_seconds": 600
  }
}