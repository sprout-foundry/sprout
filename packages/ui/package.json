{
  "name": "@sprout/ui",
  "version": "0.1.0",
  "description": "Reusable React UI components for Sprout",
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    },
    "./dist/style.css": {
      "default": "./dist/style.css"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "test": "jest --config jest.config.js",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.0",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-wast": "^6.0.2",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.1",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/lint": "^6.9.2",
    "@codemirror/lsp-client": "^6.2.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.38.8",
    "@emmetio/codemirror6-plugin": "^0.4.0",
    "@replit/codemirror-minimap": "^0.5.2",
    "@uiw/codemirror-extensions-color": "^4.25.9",
    "@uiw/codemirror-extensions-hyper-link": "^4.25.9",
    "@uiw/codemirror-extensions-line-numbers-relative": "^4.25.9",
    "@xterm/addon-clipboard": "^0.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror-lang-ruby": "^0.4.4",
    "lucide-react": "^1.0.1",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.5",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^4.9.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.0.0"
  },
  "keywords": [
    "react",
    "editor",
    "terminal",
    "ide",
    "code-editor",
    "sprout"
  ],
  "homepage": "https://github.com/sprout-foundry/sprout/tree/main/packages/ui",
  "bugs": {
    "url": "https://github.com/sprout-foundry/sprout/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sprout-foundry/sprout.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  }
}
