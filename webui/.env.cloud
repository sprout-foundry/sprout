# Cloud mode (for build-webui-dist cloud builds)
VITE_SPROUT_MODE=cloud
# VITE_FOUNDRY_API_URL and VITE_FOUNDRY_WS_URL are runtime-configurable.
# To bake specific values into the build, pass --api-url and --ws-url to
# build-webui-dist.mjs, or uncomment and set these variables:
# VITE_FOUNDRY_API_URL=https://foundry.sprout.dev/api
# VITE_FOUNDRY_WS_URL=wss://foundry.sprout.dev/ws
