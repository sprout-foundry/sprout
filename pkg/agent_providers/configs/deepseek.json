    "model_overrides": {
      "deepseek-chat": 1000000,
      "deepseek-coder": 128000,
      "deepseek-reasoner": 1000000,
      "deepseek-v3": 128000,
      "deepseek-v4-flash": 1000000,
      "deepseek-v4-flash-max": 1000000,
      "deepseek-v4-pro": 1000000
    },
    "pattern_overrides": [
      {
        "context_limit": 1000000,
        "pattern": "deepseek-v4-.*"
      },
      {
        "context_limit": 128000,
        "pattern": "deepseek-v3.*"
      },
      {
        "context_limit": 128000,
        "pattern": "deepseek-coder.*"
      }
    ],
    "supports_vision": false,
    "vision_model": ""
  },
  "name": "deepseek",
  "retry": {
    "backoff_multiplier": 2,
    "base_delay_ms": 1000,
    "max_attempts": 3,
    "max_delay_ms": 30000,
    "retryable_errors": [
      "rate_limit_exceeded",
      "temporary_error",
      "timeout"
    ]
  },
  "streaming": {
    "chunk_timeout_ms": 320000,
    "done_marker": "[DONE]",
    "format": "sse"
  },
  "display_name": "DeepSeek"
}