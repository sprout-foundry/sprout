# Sprout WebUI Environment Variables
#
# Copy this file to .env.local and fill in values.
# Variables prefixed with VITE_ are embedded at build time.
# See docs/DEPLOYMENT.md (SP-040) for full documentation.
#
# At runtime, the frontend first calls GET /api/bootstrap to get
# RuntimeConfig. These VITE_* vars serve as fallbacks when the
# bootstrap endpoint is unavailable (e.g., pure static builds).

# ── API Connectivity ──────────────────────────────────────────────

# Base URL for the Sprout API server.
# Default: http://localhost:56000
VITE_FOUNDRY_API_URL=

# WebSocket URL for real-time agent events.
# Default: ws://localhost:56000/ws
VITE_WS_URL=

# WebSocket URL for terminal sessions.
# Default: ws://localhost:56000/terminal/ws
VITE_TERMINAL_WS_URL=

# Foundry API URL (cloud mode only).
# Default: (none — only used in cloud mode)
VITE_FOUNDRY_WS_URL=

# ── Application Mode ──────────────────────────────────────────────

# Application mode: "local" (default) or "cloud".
# - local: Self-hosted/desktop, no auth required
# - cloud: Managed platform, bearer token auth required
VITE_SPROUT_MODE=local

# ── Server-Side Dev Proxy ─────────────────────────────────────────
# (Used by `npm run dev` only — not embedded in production builds)
#
# Override the backend URL for the Vite dev server proxy.
# Default: http://localhost:56000
# SPROUT_DEV_BACKEND_URL=http://localhost:56000
