{
  "auth": {
    "env_var": "",
    "type": "none"
  },
  "cost": {
    "currency": "USD",
    "input_token_cost": 0,
    "output_token_cost": 0
  },
  "defaults": {
    "max_tokens": -1,
    "model": "qwen3-coder:30b",
    "temperature": 0.7,
    "top_p": 1
  },
  "endpoint": "http://127.0.0.1:1234/v1/chat/completions",
  "headers": {},
  "message_conversion": {
    "convert_tool_role_to_user": false,
    "include_tool_call_id": false,
    "reasoning_content_field": ""
  },
  "models": {
    "available_models": [],
    "default_context_limit": 32768,
    "default_model": "qwen3-coder:30b",
    "model_overrides": {
      "llama-3-70b-instruct": 8192,
      "llama-3.1-70b-instruct": 128072,
      "mistral-7b-instruct": 32768,
      "qwen2.5-coder-32b-instruct": 32768,
      "qwen3-coder:30b": 128768,
      "yi-34b-chat": 4096
    },
    "pattern_overrides": [
      {
        "context_limit": 128072,
        "pattern": ".*llama-3\\.1.*"
      },
      {
        "context_limit": 8192,
        "pattern": ".*llama-3.*"
      },
      {
        "context_limit": 32768,
        "pattern": ".*qwen2\\.5.*"
      },
      {
        "context_limit": 16384,
        "pattern": ".*codellama.*"
      },
      {
        "context_limit": 32768,
        "pattern": ".*mistral.*"
      }
    ],
    "supports_vision": true,
    "vision_model": "gemma-3-12b-it-qat"
  },
  "name": "lmstudio",
  "retry": {
    "backoff_multiplier": 2,
    "base_delay_ms": 1000,
    "max_attempts": 3,
    "max_delay_ms": 30000,
    "retryable_errors": [
      "rate_limit_exceeded",
      "temporary_error",
      "timeout"
    ]
  },
  "streaming": {
    "chunk_timeout_ms": 300000,
    "done_marker": "[DONE]",
    "format": "sse"
  },
  "display_name": "LM Studio"
}
